{
  "name": "fuelplan-mvp",
  "version": "0.1.0",
  "private": true,
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:export": "set NEXT_OUTPUT_EXPORT=1&& next build",
    "start": "next start",
    "lint": "next lint",
    "desktop:open": "npm run build:export && electron .",
    "desktop:build": "npm run build:export && electron-packager . FuelPlan-MVP --platform=win32 --arch=x64 --out=../dist/desktop --overwrite --prune=true"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "serve-handler": "^6.1.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "@electron/packager": "^18.3.6",
    "electron": "^31.7.7",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  }
}
