# Generate with: npx web-push generate-vapid-keys
# Set the same values in Vercel Project Settings -> Environment Variables.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@example.com

# Production subscription store on Vercel.
# Use Upstash Redis REST. Without these, local dev falls back to memory only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional admin-only broadcast token for maintenance/test operations.
# Normal app traffic uses device-scoped ownership headers instead.
PUSH_ADMIN_TOKEN=
