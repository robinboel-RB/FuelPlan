# Generate with: npx web-push generate-vapid-keys
# Set the same values in Vercel Project Settings -> Environment Variables.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@example.com
NEXT_PUBLIC_APP_URL=https://your-production-domain.example

# Level 2 server scheduler. Required for server-driven Web Push reminders.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Production subscription and session store on Vercel.
# Preferred free Vercel-native MVP option: Vercel Blob.
BLOB_READ_WRITE_TOKEN=

# Optional later alternative: Upstash Redis REST.
# Storage priority is Blob -> Upstash -> local memory fallback.
# Level 2 rejects memory storage in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional Vercel Cron protection. If set, Vercel sends Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Optional admin-only broadcast token for maintenance/test operations.
# Normal app traffic uses device-scoped ownership headers instead.
PUSH_ADMIN_TOKEN=
